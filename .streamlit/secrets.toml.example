# Political Edge — Streamlit Cloud Secrets Template
# Copy this format into your Streamlit Cloud app settings under "Secrets"

# API Keys (all optional — app runs with seed data without them)
congress_gov = ""
regulations_gov = ""
fred_api_key = ""
alpaca_key_id = ""
alpaca_secret_key = ""

# Email Alert Configuration (optional)
[alerts]
email = ""
smtp_server = "smtp.gmail.com"
smtp_port = 587
smtp_user = ""
smtp_password = ""  # Gmail app password (not your regular password)
